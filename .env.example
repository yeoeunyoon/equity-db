# Copy to .env and adjust as needed: `cp .env.example .env`
# docker compose reads .env automatically.

# Application (web) -> database connection
DB_HOST=db
DB_NAME=equity_db
DB_USER=equity
DB_PASS=equity

# MySQL root password (used by the db container for init and by the refresh
# worker to reload data via server-side LOAD DATA INFILE)
MYSQL_ROOT_PASSWORD=root

# --- Data refresh worker ---
# Time of the daily regenerate+reload, in UTC (HH:MM).
REFRESH_AT=00:30
# Mode for the one-time refresh on container startup: daily (fast: all prices +
# top-50 fundamentals) or full (slow: all prices + all fundamentals).
BOOT_MODE=daily
# Optional: pin the price history window (default: last 3 years -> today).
# PRICE_START=2022-01-01
# PRICE_END=2025-01-01
